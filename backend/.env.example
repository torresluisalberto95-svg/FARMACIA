# Base de datos — Render PostgreSQL (o cualquier PostgreSQL externo)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=farmacia
DB_USER=farmaciauser
DB_PASSWORD=tu_password_aqui

# JWT — genera un secreto largo y aleatorio (mín. 32 caracteres)
JWT_SECRET=cambia-este-secreto-por-uno-muy-largo-y-aleatorio

# Admin inicial (se crea al primer arranque si no existe)
ADMIN_EMAIL=admin@mdfarmasalud.com
ADMIN_PASSWORD=Admin123!
ADMIN_FULLNAME=Administrador

# CORS — URL(s) del frontend separadas por coma
CORS_ORIGINS=https://farmaciamdapp.vercel.app,http://localhost:5173

# Puerto (Render lo asigna automáticamente via $PORT)
# PORT=8080
